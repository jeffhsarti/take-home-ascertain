# Copy to `.env` and adjust as needed: `cp .env.example .env`

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=healthcare

# --- Database URL (async SQLAlchemy / asyncpg) ---
# Local development: uvicorn runs on the host and connects to the dockerized
# Postgres published on localhost:5432.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/healthcare
# NOTE: when the backend itself runs inside docker-compose, the host is overridden
# to the service name `db` (postgresql+asyncpg://...@db:5432/healthcare).

# --- Optional: LLM-generated patient summaries ---
# Leave blank to use the deterministic template (no secrets required to run).
ANTHROPIC_API_KEY=

# --- CORS (allowed browser origins for the API) ---
BACKEND_CORS_ORIGINS=http://localhost:8080

# --- Backend concurrency & DB pool (task-18) ---
# uvicorn worker processes. Each worker has its own event loop and its own pool, so
# total DB connections = WEB_CONCURRENCY * (DB_POOL_SIZE + DB_MAX_OVERFLOW). Keep that
# under Postgres max_connections (compose sets it to 200).
WEB_CONCURRENCY=2
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
